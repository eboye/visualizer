# Maintainer: eboye
pkgname=visualizer
pkgver=0.1.1
pkgrel=1
pkgdesc="Fullscreen PipeWire audio visualizer — 3D wireframe terrain & globe with HDR bloom"
arch=('x86_64')
url="https://github.com/eboye/visualizer"
license=('MIT')
depends=('pipewire' 'dbus' 'fontconfig' 'vulkan-icd-loader' 'libxkbcommon')
makedepends=('rust' 'clang')
source=("$pkgname-$pkgver.tar.gz::https://github.com/eboye/visualizer/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    cargo build --release --locked
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 target/release/visualizer "$pkgdir/usr/bin/visualizer"
    install -Dm644 packaging/io.github.eboye.visualizer.desktop \
        "$pkgdir/usr/share/applications/io.github.eboye.visualizer.desktop"
    install -Dm644 packaging/io.github.eboye.visualizer.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/io.github.eboye.visualizer.svg"
    install -Dm644 packaging/io.github.eboye.visualizer.metainfo.xml \
        "$pkgdir/usr/share/metainfo/io.github.eboye.visualizer.metainfo.xml"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
